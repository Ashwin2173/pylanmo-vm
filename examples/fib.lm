main {
    PUSH 0 STORE count
    PUSH 0 STORE x1
    PUSH 1 STORE x2
    PUSH print LOAD x1 CALL 1 POP
    LABEL start
        PUSH print LOAD x2 CALL 1 POP
        LOAD x1 LOAD x2 BIN_OP 1
        LOAD x2 STORE x1
        STORE x2

        PUSH 1 LOAD count BIN_OP 1 STORE count
        LOAD count PUSH 9 BIN_OP 11
    JUMP_IF_FALSE start

    PUSH NONE RETURN
}

print {
    WRITE POP
    PUSH NONE RETURN
}
